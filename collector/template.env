# Logger Configuration
LOGGER_LEVEL={{LOGGER_LEVEL}}
LOGGER_MODE={{LOGGER_MODE}}
LOGGER_ENCODING={{LOGGER_ENCODING}}

# RabbitMQ Configuration
RABBITMQ_URL={{RABBITMQ_URL}}

# Redis State Configuration (for project execution state tracking)
# DB 0 is reserved for job mapping and Pub/Sub
# DB 1 is used for project state (status, total, done, errors)
REDIS_STATE_HOST={{REDIS_STATE_HOST}}
REDIS_STATE_DB={{REDIS_STATE_DB}}
REDIS_STATE_PASSWORD={{REDIS_STATE_PASSWORD}}
REDIS_STATE_POOL_SIZE={{REDIS_STATE_POOL_SIZE}}
REDIS_STATE_TTL_HOURS={{REDIS_STATE_TTL_HOURS}}

# Project Service Configuration
PROJECT_SERVICE_URL={{PROJECT_SERVICE_URL}}
PROJECT_TIMEOUT={{PROJECT_TIMEOUT}}
PROJECT_INTERNAL_KEY={{PROJECT_INTERNAL_KEY}}
WEBHOOK_RETRY_ATTEMPTS={{WEBHOOK_RETRY_ATTEMPTS}}
WEBHOOK_RETRY_DELAY={{WEBHOOK_RETRY_DELAY}}

# Discord Configuration
DISCORD_REPORT_BUG_ID={{DISCORD_REPORT_BUG_ID}}
DISCORD_REPORT_BUG_TOKEN={{DISCORD_REPORT_BUG_TOKEN}}
