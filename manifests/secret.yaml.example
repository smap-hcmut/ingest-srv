apiVersion: v1
kind: Secret
metadata:
  name: ingest-secrets
  namespace: smap
  labels:
    app: ingest-api
type: Opaque
stringData:
  # PostgreSQL Configuration
  POSTGRES_USER: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"

  # Redis Configuration
  REDIS_PASSWORD: "CHANGE_ME"

  # MinIO Configuration
  MINIO_ACCESS_KEY: "CHANGE_ME"
  MINIO_SECRET_KEY: "CHANGE_ME"

  # JWT Configuration
  JWT_SECRET_KEY: "CHANGE_ME_min_32_chars"

  # Encrypter Configuration
  ENCRYPTER_KEY: "CHANGE_ME_exactly_32_chars______"

  # Internal Configuration
  INTERNAL_INTERNAL_KEY: "CHANGE_ME"
